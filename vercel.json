{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/index.js": {
      "includeFiles": "public/**"
    }
  },
  "rewrites": [
    {
      "source": "/",
      "destination": "/api/index?__moemon_path=/"
    },
    {
      "source": "/:path*",
      "destination": "/api/index?__moemon_path=/:path*"
    }
  ]
}