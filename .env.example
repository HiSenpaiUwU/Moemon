PORT=3000
APP_ORIGIN=http://localhost:3000
SESSION_COOKIE_NAME=moemon_session
SESSION_TTL_HOURS=168

# The first account becomes admin automatically.
# You can also set an admin password bootstrap after starting the app:
# node src/tools/admin.js create-admin admin@example.com StrongPass123!

# SMTP is optional in development. If configured, password reset emails
# are sent over SMTPS (SSL/TLS) so Gmail app passwords work on port 465.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-account@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Moemon Arena <your-account@gmail.com>
